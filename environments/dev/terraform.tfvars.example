################################################################################
# General
################################################################################
project_name = "my-platform"
environment  = "dev"
region       = "eu-west-1"
owner        = "platform-team"

################################################################################
# VPC Configuration
################################################################################
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["eu-west-1a", "eu-west-1b", "eu-west-1c"]
public_subnet_cidrs   = ["10.0.0.0/20", "10.0.16.0/20", "10.0.32.0/20"]
private_subnet_cidrs  = ["10.0.64.0/20", "10.0.80.0/20", "10.0.96.0/20"]
database_subnet_cidrs = ["10.0.128.0/20", "10.0.144.0/20", "10.0.160.0/20"]
single_nat_gateway    = true  # Set false for prod HA

################################################################################
# EKS Configuration
################################################################################
cluster_version     = "1.30"
cluster_type        = "cloud"  # "cloud" or "hybrid"
node_instance_types = ["m5.large"]
node_min_size       = 2
node_max_size       = 10
node_desired_size   = 3
node_disk_size      = 50

################################################################################
# Security
################################################################################
cluster_endpoint_public_access       = false
cluster_endpoint_public_access_cidrs = []

################################################################################
# Hybrid Configuration (uncomment if cluster_type = "hybrid")
################################################################################
# remote_node_cidrs = ["172.16.0.0/16"]
# remote_pod_cidrs  = ["172.17.0.0/16"]
